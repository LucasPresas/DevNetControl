{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=DevNetControl.db"
  },
  "Jwt": {
    "Key": "REPLACE_WITH_ENV_VAR_DEVNETCONTROL_JWT_KEY",
    "Issuer": "DevNetControl",
    "Audience": "DevNetUsers"
  }
}