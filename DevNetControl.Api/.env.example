# DevNetControl - Environment Variables Example
# Copiar este archivo a .env y ajustar los valores

# JWT Configuration (OBLIGATORIO en producción)
DEVNETCONTROL_JWT_KEY=YourSuperSecretKeyWithAtLeast64CharactersHere

# Database Connection (optional, defaults to SQLite)
# DEVNETCONTROL_CONNECTION_STRING=Host=localhost;Port=5432;Database=devnetcontrol;Username=postgres;Password=yourpassword
