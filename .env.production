# ==========================================
# DevNetControl - Variables de Entorno
# ==========================================
# Copiar este archivo a .env.production y completar los valores

# PostgreSQL
POSTGRES_PASSWORD=CambiarEstaClave123!

# JWT (Mínimo 32 caracteres)
DEVNETCONTROL_JWT_KEY=GenerarClaveSecretaConAlMenos32CaracteresAqui!

# Cifrado AES para passwords de nodos VPS
DEVNETCONTROL_ENCRYPTION_KEY=ClaveDeCifradoParaLosNodos123!
